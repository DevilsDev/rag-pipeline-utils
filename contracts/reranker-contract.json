{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "reranker",
  "version": "1.0.0",
  "title": "Reranker Contract",
  "description": "Contract for reranker plugins",
  "methods": [
    {
      "name": "rerank",
      "parameters": ["query", "documents"],
      "returns": "documents"
    }
  ],
  "properties": {
    "rerank": {
      "type": "function",
      "description": "Rerank documents based on relevance to query",
      "parameters": {
        "type": "object",
        "properties": {
          "query": {
            "type": "string",
            "description": "The search query to rank documents against"
          },
          "documents": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": { "type": "string" },
                "content": { "type": "string" }
              }
            },
            "description": "Array of retrieved documents to rerank"
          },
          "options": {
            "type": "object",
            "properties": {
              "topK": {
                "type": "number",
                "description": "Maximum number of top documents to return"
              }
            }
          }
        },
        "required": ["query", "documents"]
      },
      "returns": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "content": { "type": "string" }
          }
        }
      }
    }
  },
  "required": ["rerank"]
}
